Demonstrate String Manipulation using standard library functions within a Switch-Case menu structure.

SOLUTION:
  
#include<stdio.h>
#include<string.h>
int main()
{
   int l,choice;
   char a[50],b[50];
   printf("enter string");
   scanf("%s",a);
   printf("enter the choice");
   scanf("%d",&choice);
   switch(choice)
   {
      case 1:
         l=strlen(a);
         printf("\nlength of string is %d",l);
         break;
      case 2:
         strcpy(b,a);
         printf("\noriginal string is %s",a);
         printf("\ncopied string is %s",b);
         break;
      case 3:
         printf("enter string 2");
         scanf("%s",b);
         strcat(a,b);
         printf("\nconcatenated string is %s",a);
         break;
      case 4:
         printf("enter string 2");
         scanf("%s",b);
         if(strcmp(a,b)==0)
            printf("\nstrings are equal");
         else
            printf("strings are not equal");
         break;
      default:
         printf("enter valid choice");
         break;
   }
   return 0;
}
