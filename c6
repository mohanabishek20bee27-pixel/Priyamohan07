Use a struct to store college data by state and attempts to calculate totals and find the maximum.

SOLUTION:
  
#include<stdio.h>
struct college
{
   char state[20];
   int e;
   int m;
   int md;
   int s;
};
int main()
{
   int i,n,j,max,temp,tc[206];
   struct college c[20];
   printf("enter no.\t");
   scanf("%d",&n);
   printf("\n enter state and no of clg\t");
   for(i=0;i<n;i++)
   {
      scanf("%s",c[i].state);
      scanf("%d%d%d%d",&c[i].e,&c[i].md,&c[i].s);
   }
   for(i=0;i<n;i++)
   {
      tc[i]=c[i].e+c[i].md+c[i].s;
      printf("%shas%dcolege",c[i].state,tc[i]);
   }
   for(i=0;i<n-i;i++)
   {
      for(j=i+1;j<n;j++)
      {
         if(tc[i]>tc[j])
         {
            temp=tc[i];
            tc[i]=tc[j];
            tc[j]=temp;
         }
         max=tc[j];
      }
   }
   printf("\n max no of clg is%din the state%s",max,c[i].state);
   return 0;
}
