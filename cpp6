Problem Statement:
Write a C++ program using a class to find the total number of subsets in a given array that sum up to a specific target value.
Class SubsetCounter: Create a class containing a method countSubsets that takes an array, its size, and a target sum as arguments.
Dynamic Programming Approach:Initialize a dp array where dp[i] represents the number of ways to achieve the sum i.
Set the base case: There is exactly 1 way to achieve a sum of 0 (by choosing an empty subset).

SOLUTION:

#include <iostream>
#include <vector>
using namespace std;
class SubsetCounter {
public:
    int countSubsets(int arr[], int size, int target) {
        int dp[1001] = {0};
        dp[0] = 1;
        for (int i = 0; i < size; i++) {
            // For each number, see which sums it can complete
            for (int j = target; j >= arr[i]; j--) {
                dp[j] = dp[j] + dp[j - arr[i]];
            }
        }
        return dp[target];
    }
};

int main() {
    SubsetCounter obj;
    int arr[] = {5, 2, 3, 10, 6, 8};
    int n = 6;
    int target = 10;
    cout << "Output: " << obj.countSubsets(arr, n, target);
    return 0;
}
