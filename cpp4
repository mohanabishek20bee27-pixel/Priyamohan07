Check given string is a palindrome or not>

SOLUTION:

#include <iostream>
#include <string>
using namespace std;
void check(int n) {
    int original = n, reversed = 0, rem;
    while (n > 0) {
        rem = n % 10;
        reversed = (reversed * 10) + rem;
        n /= 10;
    }
    if (original == reversed) cout << original << " is a Palindrome\n";
    else cout << original << " is not a Palindrome\n";
}
void check(string s) {
    string rev = "";
    for (int i = s.length() - 1; i >= 0; i--) {
        rev = rev + s[i];
    }
    if (s == rev) cout << s << " is a Palindrome\n";
    else cout << s << " is not a Palindrome\n";
}
int main() {
    check(121);
    check("madam");
    return 0;
}
