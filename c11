Swap numbers using function.

SOLUTION:
  
#include<stdio.h>
void swap(int,int);
int main()
{
   int a=7,b=8;
   printf("before swapping in main a=%d,b=%d\n",a,b);
   swap(a,b);
   printf("after swapping in main a=%d,b=%d\n",a,b);
}
void swap(int a,int b)
{
   int temp;
   temp=a;
   a=b;
   b=temp;
   printf("after swapping in function a=%d,b=%d\n",a,b);
}
