Create a C++ class named octal that handles decimal-to-octal conversion and allows subtraction between two octal objects.

SOLUTION:

#include<iostream>
#include<cmath>
using namespace std;
class octal
{
   int octal;
   public:
   octal()
   {
      octal=0;
   }
   octal(int dec)
   {
      oct=0;
      int i=1;
      while(dec!=0)
      {
         oct=oct+(dec%8)*i;
         dec=dec/8;
         i=i*10;
      }
   }
   octal operator=(int dec)
   {
      octal temp(dec)
         return temp;
   }
   octal operator-(octal &o)
   {
      int dec1=0,dec2=0,i=0;
      octal temp;
      while(oct!=0)
      {
         dec1=dec1+(oct%10)*pow(8,i++)
            oct=oct/10;
      }
      i=0
         while(o.oct!=0)
         {
            dec2=dec2+(o.oct%10)*pow(8,i++)
               o.oct=o.oct/10;
         }
      temp.oct=dec1-dec2;
      return temp;
   }
   void display()
   {
      cout<<oct<<endl;
   }
};
int main()
{
   int n1,n2;
   cin>>n1>>n2;
   octal o1=n1;
   cout<<"octal equivalent of"<<n1<<endl;
   o1.display()
      octal o2=n2;
    cout<<"octal equivalent of"<<n2<<endl;
    o2.display()
       octal o3=o1-o2;
    o3.display();
    return 0;
}
